---
import { Image } from 'astro:assets';
import awardsImage from '../assets/img/awards.webp';
import award1 from '../assets/img/award1.webp';
import award2 from '../assets/img/award2.webp';
import award3 from '../assets/img/award3.webp';
import award4 from '../assets/img/award4.webp';
import award5 from '../assets/img/award5.webp';
import award6 from '../assets/img/award6.webp';

// Swiper + EffectExpo CSS — MUST live in the frontmatter so Astro includes
// them in the page's CSS bundle and manages them during View Transitions.
// When imported inside <script>, Vite injects <style> tags as a module
// side-effect. After VT navigation the module is cached (ES module map)
// and does NOT re-execute, so swapHeadElements() removes the styles and
// they are never re-injected. Moving them here makes Astro treat them
// the same as scoped component CSS: properly added/removed during VT swap.
import 'swiper/css';
import 'swiper/css/navigation';
import 'swiper/css/pagination';
import '../assets/uiinitiative-expo-slider-c4e29dd4d6c81e6d2f6654e11d368cd46ea563ac/demo-vite/effect-expo.css';

const awardSlides = [
	{ src: award1.src, alt: 'Award gallery image 1' },
	{ src: award2.src, alt: 'Award gallery image 2' },
	{ src: award3.src, alt: 'Award gallery image 3' },
	{ src: award4.src, alt: 'Award gallery image 4' },
	{ src: award5.src, alt: 'Award gallery image 5' },
	{ src: award6.src, alt: 'Award gallery image 6' },
];
---

<section class="bg-cream py-14 sm:py-18 lg:py-24">
	<div class="mx-auto w-full max-w-330 px-4 sm:px-8 lg:px-16">
		<header class="text-center">
			<p class="font-body text-[0.68rem] font-semibold uppercase tracking-[2.8px] text-gold-dark/80 sm:text-[0.72rem]">
				Bengal Excellence
			</p>
			<h2 class="mt-3 font-heading text-[2.2rem] font-medium tracking-tight text-dark sm:text-[2.8rem] lg:text-[3.3rem]">
				Awards
			</h2>
			<span class="mx-auto mt-4 block h-px w-24 bg-(--gold-line) sm:w-28"></span>
		</header>

		<div class="mt-10 grid grid-cols-1 items-start gap-8 sm:mt-12 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:gap-10">
			<figure class="overflow-hidden rounded-[20px] border border-gold/18 bg-[#f8f3eb]">
				<Image
					src={awardsImage}
					alt="Luxury Rosettes award trophy"
					class="h-full w-full object-cover"
					widths={[640, 900, 1200, 1600]}
					sizes="(max-width: 1024px) 100vw, 46vw"
					loading="lazy"
					format="webp"
				/>
			</figure>

			<div class="text-left">
				<p class="font-body text-[0.68rem] font-semibold uppercase tracking-[2.6px] text-gold-dark/80 sm:text-[0.72rem]">
					Bengal Cat Association
				</p>
				<h3 class="mt-3 font-heading text-[1.8rem] font-medium leading-tight tracking-tight text-dark sm:text-[2.2rem] lg:text-[2.6rem]">
					Brown (Black) Spotted Male Adult
				</h3>

				<div class="mt-5 space-y-5 font-body text-[1rem] leading-[1.76] text-text-primary sm:text-[1.08rem] lg:text-[1.15rem]">
					<p>
						We are honored that our Bengals have been recognized with numerous prestigious awards from the Bengal Cat Association. Among the distinctions received are First Place in multiple classes, Best of Breed, Best in Show Adult, and the highly coveted title of Overall Best in Show Bengal 2024.
					</p>
					<p>
						Each of these awards reflects the very best qualities of the Bengal breed striking beauty, exceptional coat pattern, robust health, and a gentle yet confident temperament. Such recognition is only given to cats that truly embody the breed standard and stand out in the eyes of international judges.
					</p>
					<p>
						For us, these achievements go beyond trophies and ribbons. They are a testament to the years of dedication, care, and passion we have invested in our breeding program. They confirm that our Bengals are not only admired in the show hall but also respected within the wider Bengal community.
					</p>
					<p>
						We are proud to share these accomplishments with families who welcome our Bengals into their homes, knowing they are bringing in a cat of outstanding quality and proven excellence.
					</p>
				</div>

				<div class="mt-7 inline-flex rounded-md border border-gold/35 px-5 py-2.5" aria-label="Official recognition label">
					<span class="font-body text-[0.7rem] font-semibold uppercase tracking-[2.6px] text-gold-dark/85">Official Recognition</span>
				</div>
			</div>
		</div>
	</div>

	<div class="mt-14 border-t border-gold/15 pt-10 sm:mt-16 sm:pt-12">
		<div class="mx-auto mb-6 w-full max-w-330 px-4 text-center sm:mb-8 sm:px-8 lg:px-16">
			<p class="font-body text-[0.66rem] font-semibold uppercase tracking-[2.6px] text-gold-dark/80 sm:text-[0.7rem]">
				Awards Gallery
			</p>
			<h3 class="mt-2 font-heading text-[1.5rem] font-medium tracking-tight text-dark sm:text-[1.9rem] lg:text-[2.2rem]">
				Show Highlights
			</h3>
		</div>

		<div class="awards-expo-wrap relative overflow-hidden">
			<div class="awards-expo-swiper swiper swiper-expo">
				<div class="swiper-wrapper">
					{awardSlides.map((slide) => (
						<div class="swiper-slide">
							<div class="expo-container">
								<img class="expo-image" src={slide.src} alt={slide.alt} loading="lazy" />
								<div class="expo-content"></div>
							</div>
						</div>
					))}
				</div>
				<div class="awards-expo-nav awards-expo-prev" aria-label="Previous slide"></div>
				<div class="awards-expo-nav awards-expo-next" aria-label="Next slide"></div>
				<div class="awards-expo-pagination"></div>
			</div>
		</div>
	</div>
</section>

<style>
	.awards-expo-wrap {
		--swiper-navigation-color: #9f7f2f;
		--swiper-pagination-color: #b18b2f;
	}

	.awards-expo-wrap :global(.awards-expo-swiper) {
		height: clamp(260px, 56vw, 520px);
		overflow: visible;
	}

	@media (min-width: 768px) {
		.awards-expo-wrap :global(.awards-expo-swiper) {
			height: clamp(400px, 52vw, 600px);
		}
	}

	@media (min-width: 1280px) {
		.awards-expo-wrap :global(.awards-expo-swiper) {
			height: 100vh;
		}
	}

	.awards-expo-wrap :global(.expo-container) {
		transform-style: flat;
		border-radius: var(--expo-image-border-radius, 16px);
	}

	.awards-expo-wrap :global(.expo-image) {
		border-radius: var(--expo-image-border-radius, 16px);
	}

	.awards-expo-wrap :global(.expo-content) {
		display: none;
	}

	.awards-expo-wrap :global(.awards-expo-nav) {
		position: absolute;
		top: 50%;
		z-index: 20;
		display: grid;
		height: 40px;
		width: 40px;
		place-items: center;
		border: 1px solid rgba(212, 175, 55, 0.35);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.86);
		transform: translateY(-50%);
		cursor: pointer;
	}

	.awards-expo-wrap :global(.awards-expo-prev) {
		left: 10px;
	}

	.awards-expo-wrap :global(.awards-expo-next) {
		right: 10px;
	}

	.awards-expo-wrap :global(.awards-expo-nav)::after {
		font-size: 14px;
		font-weight: 700;
	}

	.awards-expo-wrap :global(.awards-expo-prev)::after {
		content: '\2039';
	}

	.awards-expo-wrap :global(.awards-expo-next)::after {
		content: '\203A';
	}

	.awards-expo-wrap :global(.awards-expo-pagination) {
		margin-top: 14px;
		position: static;
		text-align: center;
	}

	@media (max-width: 767px) {
		.awards-expo-wrap :global(.awards-expo-nav) {
			display: none;
		}
	}
</style>

<script>
	import Swiper from 'swiper';
	import { Navigation, Pagination } from 'swiper/modules';
	// @ts-ignore
	import EffectExpo from '../assets/uiinitiative-expo-slider-c4e29dd4d6c81e6d2f6654e11d368cd46ea563ac/demo-vite/effect-expo.esm.js';

	let swiperInstance: InstanceType<typeof Swiper> | null = null;
	let pristineHTML = '';

	function createSwiper(el: HTMLElement) {
		swiperInstance = new Swiper(el, {
			modules: [Navigation, Pagination, EffectExpo],
			effect: 'expo',
			slidesPerView: 1.18,
			spaceBetween: 10,
			speed: 1400,
			grabCursor: true,
			expoEffect: {
				imageScale: 1.05,
				imageOffset: 0.8,
				scale: 1.08,
				rotate: 0,
				grayscale: true,
			},
			navigation: {
				nextEl: el.querySelector('.awards-expo-next'),
				prevEl: el.querySelector('.awards-expo-prev'),
			},
			pagination: {
				el: el.querySelector('.awards-expo-pagination'),
				clickable: true,
			},
			breakpoints: {
				640: { slidesPerView: 1.35, spaceBetween: 12 },
				768: { slidesPerView: 1.25, spaceBetween: 14 },
				1024: { slidesPerView: 1.35, spaceBetween: 16 },
				1280: { slidesPerView: 1.55, spaceBetween: 16 },
			},
		});
	}

	function destroyAwardsExpo() {
		if (swiperInstance) {
			try { swiperInstance.destroy(true, true); } catch (e) { /* noop */ }
			swiperInstance = null;
		}
	}

	function initAwardsExpo() {
		destroyAwardsExpo();

		const wrap = document.querySelector('.awards-expo-wrap');
		if (!wrap) return;

		// First run: snapshot server-rendered markup before Swiper mutates it.
		// String lives in module scope — immune to VT DOM contamination.
		if (!pristineHTML) {
			pristineHTML = wrap.innerHTML;
		} else {
			// VT return: nuke stale VT-cached DOM, restore pristine.
			wrap.innerHTML = pristineHTML;
		}

		const el = wrap.querySelector('.awards-expo-swiper') as HTMLElement | null;
		if (!el) return;

		// Single rAF: let the browser lay out the restored DOM.
		// CSS is now managed by Astro's pipeline (frontmatter imports),
		// so it's guaranteed to be in <head> before astro:page-load fires.
		requestAnimationFrame(() => {
			if (!el!.isConnected) return;
			createSwiper(el!);

			// Safety net: force EffectExpo.setSize() recalc after layout settles.
			// Harmless if dimensions are already correct.
			setTimeout(() => {
				if (swiperInstance) swiperInstance.update();
			}, 200);
		});
	}

	document.addEventListener('astro:page-load', initAwardsExpo);
	document.addEventListener('astro:before-swap', destroyAwardsExpo);
</script>


