---
---

<section class="journey-section bg-cream">
	<div class="journey-inner">
		<header class="journey-header">
			<p class="font-body text-[0.68rem] font-semibold uppercase tracking-[2.8px] text-gold-dark/80 sm:text-[0.72rem]">
				Bengal Excellence
			</p>
			<h2 class="mt-3 font-heading text-[2.2rem] font-medium tracking-tight text-dark sm:text-[2.8rem] lg:text-[3.3rem]">
				Your Bengal Journey Starts Here
			</h2>
			<span class="mx-auto mt-4 block h-px w-24 bg-(--gold-line) sm:w-28"></span>
		</header>

		<div class="showcase-container">
			<!-- Left Side - Interactive List -->
			<div class="showcase-list">
				<div class="showcase-item active" data-target="kittens">
					<h3 class="showcase-title">Our Kittens</h3>
				</div>
				<div class="showcase-item" data-target="parents">
					<h3 class="showcase-title">Champion Parents</h3>
				</div>
				<div class="showcase-item" data-target="care">
					<h3 class="showcase-title">Premium Care</h3>
				</div>
				<div class="showcase-item" data-target="standards">
					<h3 class="showcase-title">Our Standards</h3>
				</div>
			</div>

			<!-- Right Side - Content Slides -->
			<div class="showcase-content">
				<div class="content-slide active" id="slide-kittens">
					<div class="content-background" style="background-image: url('https://luxuryrosettes.co.uk/wp-content/uploads/2025/10/Cosmo-3-origi.webp');"></div>
					<div class="content-overlay"></div>
					<div class="content-inner">
						<h2 class="content-heading">Exquisite Bengal Kittens</h2>
						<p class="content-description">
							Each kitten from our cattery showcases the stunning rosette patterns and wild beauty that Bengal cats are celebrated for. Raised with love in our family home, our kittens are well-socialized, healthy, and ready to become cherished members of your family.
						</p>
						<a href="https://luxuryrosettes.co.uk/available-kittens/" class="content-button"><span>View Available Kittens</span></a>
					</div>
				</div>

				<div class="content-slide" id="slide-parents">
					<div class="content-background" style="background-image: url('https://luxuryrosettes.co.uk/wp-content/uploads/2025/11/our-cats-section-picture-web-e1762458616249.webp');"></div>
					<div class="content-overlay"></div>
					<div class="content-inner">
						<h2 class="content-heading">Champion Bloodlines</h2>
						<p class="content-description">
							Our breeding cats are carefully selected champions with exceptional pedigrees. With TICA registration and proven show records, our queens and studs produce kittens with outstanding rosette clarity, contrast, and the distinctive glittered coat that defines luxury Bengals.
						</p>
						<a href="https://luxuryrosettes.co.uk/our-cats/" class="content-button"><span>Meet Our Parents</span></a>
					</div>
				</div>

				<div class="content-slide" id="slide-care">
					<div class="content-background" style="background-image: url('https://luxuryrosettes.co.uk/wp-content/uploads/2025/10/Cosmo-1-webp.webp');"></div>
					<div class="content-overlay"></div>
					<div class="content-inner">
						<h2 class="content-heading">Premium Care &amp; Health</h2>
						<p class="content-description">
							Every kitten receives comprehensive veterinary care, premium nutrition, and early socialization. We provide health guarantees, complete vaccination records, and lifetime breeder support. Our kittens are raised underfoot, ensuring confident, affectionate personalities.
						</p>
						<a href="https://luxuryrosettes.co.uk/premium-care/" class="content-button"><span>Our Care Program</span></a>
					</div>
				</div>

				<div class="content-slide" id="slide-standards">
					<div class="content-background" style="background-image: url('https://luxuryrosettes.co.uk/wp-content/uploads/2025/11/our-standards.webp');"></div>
					<div class="content-overlay"></div>
					<div class="content-inner">
						<h2 class="content-heading">Exceptional Standards</h2>
						<p class="content-description">
							We are dedicated to breeding Bengal cats that exemplify the breed standard with spectacular rosettes, muscular builds, and captivating wild appearance. Our commitment to ethical breeding practices, genetic health testing, and temperament ensures kittens of extraordinary quality.
						</p>
						<a href="https://luxuryrosettes.co.uk/our-standards-2/" class="content-button"><span>Learn Our Standards</span></a>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.journey-section {
		width: 100%;
		padding: 5rem 0 0;
	}

	.journey-header {
		text-align: center;
		padding: 0 1rem 3rem;
	}

	.showcase-container {
		display: grid;
		grid-template-columns: 380px 1fr;
		min-height: 80vh;
	}

	/* Left list */
	.showcase-list {
		background: var(--cream);
		padding: 40px 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0;
		position: relative;
		z-index: 2;
		border-right: 1px solid rgba(212, 175, 55, 0.15);
	}

	.showcase-item {
		padding: 30px 48px;
		cursor: pointer;
		position: relative;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		border-left: 3px solid transparent;
	}

	.showcase-item::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0;
		width: 0;
		height: 100%;
		background: rgba(212, 175, 55, 0.1);
		transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.showcase-item:hover::before,
	.showcase-item.active::before {
		width: 100%;
	}

	.showcase-item:hover,
	.showcase-item.active {
		border-left-color: var(--gold);
	}

	.showcase-item.active {
		background: rgba(212, 175, 55, 0.08);
	}

	.showcase-title {
		font-family: var(--font-heading);
		font-size: 2.2rem;
		color: var(--dark);
		font-weight: 400;
		line-height: 1.2;
		transition: color 0.3s ease;
		position: relative;
		z-index: 1;
	}

	.showcase-item:hover .showcase-title,
	.showcase-item.active .showcase-title {
		color: var(--gold-dark);
	}

	/* Right content */
	.showcase-content {
		position: relative;
		overflow: hidden;
	}

	.content-slide {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		opacity: 0;
		visibility: hidden;
		transition:
			opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
			transform 0.6s cubic-bezier(0.4, 0, 0.2, 1),
			visibility 0.6s;
		transform: scale(1.04);
	}

	.content-slide.active {
		opacity: 1;
		visibility: visible;
		transform: scale(1);
	}

	.content-background {
		position: absolute;
		inset: 0;
		background-size: cover;
		background-position: center;
		will-change: transform;
	}

	.content-slide.active .content-background {
		animation: kenBurns 20s ease-in-out infinite alternate;
	}

	@keyframes kenBurns {
		0% { transform: scale(1); }
		50% { transform: scale(1.03); }
		100% { transform: scale(1.01); }
	}

	.content-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(26, 26, 26, 0.55) 0%, rgba(107, 87, 68, 0.4) 100%);
		pointer-events: none;
	}

	.content-inner {
		position: relative;
		z-index: 2;
		padding: 8%;
		height: 100%;
		display: flex;
		flex-direction: column;
		justify-content: center;
		color: var(--cream);
	}

	.content-heading {
		font-family: var(--font-heading);
		font-size: 3.2rem;
		font-weight: 400;
		margin-bottom: 1.5rem;
		color: var(--cream);
		line-height: 1.15;
	}

	.content-slide.active .content-heading {
		animation: slideInRight 0.7s ease both;
	}

	.content-slide.active .content-description {
		animation: slideInRight 0.7s ease 0.15s both;
	}

	.content-slide.active .content-button {
		animation: slideInRight 0.7s ease 0.3s both;
	}

	@keyframes slideInRight {
		from {
			opacity: 0;
			transform: translateX(40px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	.content-description {
		font-family: var(--font-body);
		font-size: 1.05rem;
		font-weight: 400;
		line-height: 1.8;
		color: rgba(250, 248, 243, 0.88);
		max-width: 580px;
		margin-bottom: 2.5rem;
	}

	/* Button */
	.content-button {
		display: inline-block;
		padding: 0.9rem 2.4rem;
		background: linear-gradient(135deg, #d4af37 0%, #e8c96f 45%, #c59a2f 100%);
		border: 1px solid rgba(212, 175, 55, 0.4);
		border-radius: 6px;
		color: white;
		text-decoration: none;
		font-family: var(--font-body);
		font-size: 0.74rem;
		font-weight: 600;
		letter-spacing: 3px;
		text-transform: uppercase;
		cursor: pointer;
		transition: transform 0.5s ease-out, box-shadow 0.5s ease-out;
		position: relative;
		overflow: hidden;
		align-self: flex-start;
	}

	.content-button::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(115deg, transparent 20%, rgba(255, 255, 255, 0.35) 50%, transparent 80%);
		opacity: 0;
		transform: translateX(-120%);
		transition: transform 0.7s ease, opacity 0.7s ease;
		pointer-events: none;
		z-index: 0;
	}

	.content-button:hover::before {
		transform: translateX(120%);
		opacity: 1;
	}

	.content-button span {
		position: relative;
		z-index: 1;
	}

	.content-button:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-gold-strong);
	}

	/* Tablet */
	@media (max-width: 1199px) {
		.showcase-container {
			grid-template-columns: 300px 1fr;
		}

		.showcase-item {
			padding: 26px 32px;
		}

		.showcase-title {
			font-size: 1.8rem;
		}

		.content-heading {
			font-size: 2.6rem;
		}
	}

	/* Mobile */
	@media (max-width: 767px) {
		.journey-section {
			padding-top: 3.5rem;
		}

		.showcase-container {
			grid-template-columns: 1fr;
			min-height: auto;
		}

		.showcase-list {
			padding: 24px 16px;
			border-right: none;
			border-bottom: 1px solid rgba(212, 175, 55, 0.15);
			gap: 4px;
		}

		.showcase-item {
			padding: 18px 22px;
		}

		.showcase-title {
			font-size: 1.45rem;
		}

		.showcase-content {
			min-height: 70vh;
		}

		.content-slide {
			position: relative !important;
			display: none;
			opacity: 1 !important;
			visibility: visible !important;
			transform: none !important;
			min-height: 70vh;
		}

		.content-slide.active {
			display: block;
		}

		.content-slide.active .content-background {
			animation: none;
		}

		.content-background {
			position: absolute;
		}

		.content-inner {
			padding: 48px 28px;
			min-height: 70vh;
		}

		.content-heading {
			font-size: 2rem;
		}

		.content-description {
			font-size: 0.95rem;
			line-height: 1.7;
		}

		.content-button {
			align-self: stretch;
			text-align: center;
		}
	}

	@media (max-width: 480px) {
		.showcase-item {
			padding: 15px 18px;
		}

		.showcase-title {
			font-size: 1.25rem;
		}

		.content-heading {
			font-size: 1.75rem;
			margin-bottom: 1rem;
		}

		.content-description {
			font-size: 0.9rem;
			margin-bottom: 1.75rem;
		}

		.content-inner {
			padding: 36px 22px;
		}
	}
</style>

<script>
	function initJourney() {
		const items = document.querySelectorAll<HTMLElement>('.showcase-item');
		const slides = document.querySelectorAll<HTMLElement>('.content-slide');

		if (!items.length || !slides.length) return;

		function activate(target: string) {
			items.forEach((i) => i.classList.remove('active'));
			slides.forEach((s) => s.classList.remove('active'));
			const item = document.querySelector<HTMLElement>(`.showcase-item[data-target="${target}"]`);
			const slide = document.getElementById(`slide-${target}`);
			if (item) item.classList.add('active');
			if (slide) slide.classList.add('active');
		}

		if (window.innerWidth > 767) {
			items.forEach((item) => {
				item.addEventListener('mouseenter', () => {
					activate(item.dataset.target!);
				});
			});
		}

		items.forEach((item) => {
			item.addEventListener('click', () => {
				activate(item.dataset.target!);
			});
		});
	}

	document.addEventListener('astro:page-load', initJourney);
</script>
